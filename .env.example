# Copier ce fichier en .env et remplir les valeurs

# Django
SECRET_KEY=change-me-generate-a-strong-secret-key
DEBUG=False
ALLOWED_HOSTS=muziart-api.arthania.fr

# Base de données PostgreSQL
# Format CapRover : postgres://user:password@srv-captain--nom-app-postgres/db_name
DATABASE_URL=postgres://muziart:password@srv-captain--muziart-db/muziart

# URL du frontend (utilisée pour CORS et CSRF)
# Sans protocole — le settings.py ajoute http:// ou https:// selon DEBUG
FRONTEND_URL=muziart.arthania.fr

# Domaine partagé pour les cookies session et CSRF (doit couvrir front + back)
# Mettre le domaine parent avec un point devant : .arthania.fr
COOKIE_DOMAIN=.arthania.fr
